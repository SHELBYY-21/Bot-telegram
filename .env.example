# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Cursor API key (Dashboard → Integrations → API Keys)
CURSOR_API_KEY=

# Optional: restrict who can use the bot (Telegram user IDs, comma/space separated)
ALLOWED_USER_IDS=

# Optional defaults
DEFAULT_REPOSITORY=https://github.com/your-org/your-repo
DEFAULT_MODEL=
AUTO_CREATE_PR=false
POLL_INTERVAL_SECONDS=30
